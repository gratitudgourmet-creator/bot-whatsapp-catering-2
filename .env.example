# Entorno
NODE_ENV=production
PORT=3080
PANEL_HOST=0.0.0.0

# En hosting web conviene dejar el bot de WhatsApp apagado y usar solo el ERP/panel.
BOT_SKIP_WHATSAPP=1

# Carpeta persistente. En Render/Railway/Fly/etc. apuntar a un volumen persistente.
DATA_DIR=./data

# Seguridad del panel
PANEL_AUTH_USER=admin
PANEL_AUTH_PASSWORD=cambiar-esta-contrasena
PANEL_SESSION_SECRET=cambiar-por-un-texto-largo-aleatorio

# Integraciones
PURCHASE_WEBHOOK_URL=
BUDGET_WEBHOOK_URL=
OPENAI_API_KEY=

# Limites y backups
MAX_JSON_BODY_BYTES=15728640
JSON_BACKUPS=1
JSON_BACKUP_KEEP=30
